# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/blueprintai_dev
DB_POOL_MAX=20

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=blueprintai-pdfs-dev

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Authentication (optional in dev — if empty, auth is skipped)
API_KEY=

# CORS — Comma-separated allowed origins (use * for development)
CORS_ORIGIN=*

# Note: Rate limiting not yet implemented (planned for future REQ)
# Note: notifyJobCompletion() webhook service is wired but called by extraction worker (REQ-10/11)
